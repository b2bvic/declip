IS_TTY = sys.stdout.isatty()


class Spinner:
    """Half-moon rotation spinner — ◐◓◑◒.
    TTY: animated in-place.  Non-TTY: static ◐ line on enter."""

    def __init__(self, message: str):
        self.message = message
        self._stop = threading.Event()
        self._thread = None
        self._frame = 0

    def __enter__(self):
        if IS_TTY:
            self._thread = threading.Thread(target=self._spin, daemon=True)
            self._thread.start()
        else:
            click.echo(f"  {CYAN}◐{RESET} {self.message}")
        return self

    def __exit__(self, *args):
        self._stop.set()
        if self._thread:
            self._thread.join()
            sys.stdout.write(f"\r{CLEAR_LINE}")
            sys.stdout.flush()

    def _spin(self):
        while not self._stop.is_set():
            frame = SPINNER_FRAMES[self._frame % len(SPINNER_FRAMES)]
            sys.stdout.write(f"\r{CLEAR_LINE}  {CYAN}{frame}{RESET} {self.message}")
            sys.stdout.flush()
            self._frame += 1
            self._stop.wait(0.1)

    def update(self, message: str):
        self.message = message


def progress_tick(i: int, n: int, label: str, milestones: set | None = None):
    """Emit milestone progress lines in non-TTY mode.
    TTY mode: overwrite single line. Non-TTY: print at 25/50/75/100%."""
    if IS_TTY:
        sys.stdout.write(f"\r{CLEAR_LINE}  {CYAN}◐{RESET} {label} {i + 1}/{n}")
        sys.stdout.flush()
        return
    # Non-TTY: emit at milestone percentages
    if milestones is None:
        return
    pct = int((i + 1) / n * 100) if n > 0 else 100
    if pct in milestones:
        milestones.discard(pct)
        click.echo(f"    {DIM}{pct}% — {label} {i + 1}/{n}{RESET}")


