# ── Media Probing ──────────────────────────────────────────


def probe_media(path: Path) -> dict:
    """Get media info via ffprobe."""
    cmd = [
        "ffprobe", "-v", "quiet", "-print_format", "json",
        "-show_format", "-show_streams", str(path),
    ]
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        raise click.ClickException(f"ffprobe failed: {result.stderr.strip()}")
    return json.loads(result.stdout)


def get_duration(info: dict) -> float:
    """Extract duration from probe info."""
    if "format" in info and "duration" in info["format"]:
        return float(info["format"]["duration"])
    for stream in info.get("streams", []):
        if "duration" in stream:
            return float(stream["duration"])
    raise click.ClickException("Cannot determine media duration")


def has_video(info: dict) -> bool:
    """Check if media has a video stream."""
    return any(s.get("codec_type") == "video" for s in info.get("streams", []))


def has_audio(info: dict) -> bool:
    """Check if media has an audio stream."""
    return any(s.get("codec_type") == "audio" for s in info.get("streams", []))


def get_audio_sample_rate(info: dict) -> int:
    """Get audio sample rate."""
    for s in info.get("streams", []):
        if s.get("codec_type") == "audio":
            return int(s.get("sample_rate", 48000))
    return 48000


# ── Audio Extraction ───────────────────────────────────────


def extract_audio(input_path: Path, tmp_dir: Path) -> Path:
    """Extract audio to WAV for Whisper/Resemble processing."""
    wav_path = tmp_dir / "audio.wav"
    cmd = [
        "ffmpeg", "-y", "-i", str(input_path),
        "-vn", "-acodec", "pcm_s16le", "-ar", "16000", "-ac", "1",
        str(wav_path),
    ]
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        raise click.ClickException(f"Audio extraction failed: {result.stderr.strip()}")
    return wav_path


def extract_audio_fullrate(input_path: Path, tmp_dir: Path) -> Path:
    """Extract audio at original sample rate for Resemble Enhance."""
    wav_path = tmp_dir / "audio_full.wav"
    cmd = [
        "ffmpeg", "-y", "-i", str(input_path),
        "-vn", "-acodec", "pcm_s16le", "-ac", "1",
        str(wav_path),
    ]
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        raise click.ClickException(f"Audio extraction failed: {result.stderr.strip()}")
    return wav_path


# ── File Hashing (for caching) ─────────────────────────────


def file_hash(path: Path) -> str:
    """Quick hash for cache keying. Uses first/last 64KB + file size."""
    h = hashlib.sha256()
    size = path.stat().st_size
    h.update(str(size).encode())
    with open(path, "rb") as f:
        h.update(f.read(65536))
        if size > 65536:
            f.seek(-65536, 2)
            h.update(f.read(65536))
    return h.hexdigest()[:16]


# ── Transcription ──────────────────────────────────────────


def transcribe(audio_path: Path, model_name: str, use_cache: bool = True) -> dict:
    """Transcribe audio using mlx-whisper with Metal acceleration."""
    cache_key = file_hash(audio_path)
    cache_file = TRANSCRIPT_CACHE / f"{cache_key}.json"

    if use_cache and cache_file.exists():
        click.echo(f"  Using cached transcript: {cache_file.name}")
        return json.loads(cache_file.read_text())

    click.echo(f"  Transcribing with {model_name} (Metal GPU)...")
    t0 = time.time()

    import mlx_whisper
    result = mlx_whisper.transcribe(
        str(audio_path),
        path_or_hf_repo=model_name,
        word_timestamps=True,
        language="en",
    )

    elapsed = time.time() - t0
    click.echo(f"  Transcribed in {elapsed:.1f}s")

    # Cache the result
    TRANSCRIPT_CACHE.mkdir(parents=True, exist_ok=True)
    cache_file.write_text(json.dumps(result, default=str))

    return result


# ── Filler Detection ───────────────────────────────────────


def load_fillers() -> set[str]:
    """Load filler word list from config or defaults."""
    if FILLERS_FILE.exists():
        words = set()
        for line in FILLERS_FILE.read_text().splitlines():
            line = line.strip().lower()
            if line and not line.startswith("#"):
                words.add(line)
        return words if words else DEFAULT_FILLERS
    return DEFAULT_FILLERS


def is_sentence_start(words: list[dict], idx: int) -> bool:
    """Check if word at idx appears to be at a sentence/clause start."""
    if idx == 0:
        return True
    prev = words[idx - 1]
    curr = words[idx]
    # Gap > 300ms suggests sentence boundary
    gap = curr.get("start", 0) - prev.get("end", 0)
    if gap > 0.3:
        return True
    # Previous word ends with sentence-ending punctuation
    prev_word = prev.get("word", "").strip()
    if prev_word and prev_word[-1] in ".!?":
        return True
    return False


def has_following_pause(words: list[dict], idx: int, threshold: float = 0.2) -> bool:
    """Check if there's a pause after the word at idx."""
    if idx >= len(words) - 1:
        return True
    curr = words[idx]
    nxt = words[idx + 1]
    gap = nxt.get("start", 0) - curr.get("end", 0)
    return gap > threshold


def detect_fillers(
    transcript: dict,
    fillers: set[str],
    min_confidence: float = 0.5,
    margin_ms: float = 80,
) -> list[CutRegion]:
    """Detect filler words with context-aware false positive reduction."""
    cuts = []

    for segment in transcript.get("segments", []):
        words = segment.get("words", [])
        skip_next = False

        for i, w in enumerate(words):
            if skip_next:
                skip_next = False
                continue

            word_text = w.get("word", "").strip().lower()
            word_text = re.sub(r"[^\w\s']", "", word_text)
            confidence = w.get("probability", w.get("confidence", 1.0))
            start = w.get("start", 0)
            end = w.get("end", 0)

            if not word_text or end <= start:
                continue

            # Check two-word fillers first
            if i < len(words) - 1:
                next_word = words[i + 1].get("word", "").strip().lower()
                next_word = re.sub(r"[^\w\s']", "", next_word)
                two_word = f"{word_text} {next_word}"
                if two_word in fillers:
                    cuts.append(CutRegion(
                        start=start,
                        end=words[i + 1].get("end", end),
                        word=two_word,
                        confidence=min(confidence, words[i + 1].get("probability", 1.0)),
                    ))
                    skip_next = True
                    continue

            # Single-word filler check
            if word_text not in fillers:
                continue

            # Context rules for ambiguous fillers
            if word_text in CONTEXT_FILLERS:
                if word_text == "like" and confidence >= min_confidence:
                    continue  # Probably semantic "I like this"
                if word_text in ("so", "well") and not is_sentence_start(words, i):
                    continue  # Mid-sentence "so" is usually meaningful
                if word_text == "right" and not has_following_pause(words, i):
                    continue  # "right now", "right there" — not filler
                if word_text == "actually" and not has_following_pause(words, i):
                    continue  # "actually works" — not filler

            cuts.append(CutRegion(
                start=start, end=end,
                word=word_text, confidence=confidence,
            ))

    return merge_cuts(cuts, margin_ms)


def merge_cuts(cuts: list[CutRegion], margin_ms: float) -> list[CutRegion]:
    """Merge adjacent/overlapping cut regions and apply margin."""
    if not cuts:
        return []

    margin = margin_ms / 1000.0
    # Sort by start time
    cuts = sorted(cuts, key=lambda c: c.start)

    merged = []
    current = CutRegion(
        start=max(0, cuts[0].start - margin),
        end=cuts[0].end + margin,
        word=cuts[0].word,
        confidence=cuts[0].confidence,
    )

    for cut in cuts[1:]:
        expanded_start = max(0, cut.start - margin)
        expanded_end = cut.end + margin

        if expanded_start <= current.end:
            # Overlapping — merge
            current = CutRegion(
                start=current.start,
                end=max(current.end, expanded_end),
                word=f"{current.word}, {cut.word}",
                confidence=min(current.confidence, cut.confidence),
            )
        else:
            merged.append(current)
            current = CutRegion(
                start=expanded_start, end=expanded_end,
                word=cut.word, confidence=cut.confidence,
            )

    merged.append(current)

    # Second pass: collapse clusters where speech between cuts is < 200ms
    # These create machine-gun jump cuts from tiny fragments (breaths, mouth sounds)
    if len(merged) < 2:
        return merged
    collapsed = [merged[0]]
    for cut in merged[1:]:
        gap = cut.start - collapsed[-1].end
        if gap < 0.2:
            # Absorb the tiny speech fragment — merge into one continuous cut
            collapsed[-1] = CutRegion(
                start=collapsed[-1].start,
                end=max(collapsed[-1].end, cut.end),
                word=f"{collapsed[-1].word}, {cut.word}",
                confidence=min(collapsed[-1].confidence, cut.confidence),
            )
        else:
            collapsed.append(cut)
    return collapsed


def detect_gaps(transcript: dict, max_gap_ms: float = 300) -> list[CutRegion]:
    """Find word gaps exceeding max_gap_ms and create cuts to compress them."""
    if max_gap_ms <= 0:
        return []

    max_gap = max_gap_ms / 1000.0
    cuts = []

    for segment in transcript.get("segments", []):
        words = segment.get("words", [])
        for i in range(len(words) - 1):
            curr_end = words[i].get("end", 0)
            next_start = words[i + 1].get("start", 0)
            gap = next_start - curr_end

            if gap > max_gap:
                # Cut the excess, keeping max_gap worth of silence
                trim = gap - max_gap
                # Cut from the middle of the gap
                cut_start = curr_end + (max_gap / 2)
                cut_end = cut_start + trim
                cuts.append(CutRegion(
                    start=cut_start,
                    end=cut_end,
                    word=f"gap ({gap:.2f}s→{max_gap:.2f}s)",
                    confidence=1.0,
                ))

    # Also check gaps between segments
    segments = transcript.get("segments", [])
    for i in range(len(segments) - 1):
        curr_end = segments[i].get("end", 0)
        next_start = segments[i + 1].get("start", 0)
        gap = next_start - curr_end

        if gap > max_gap:
            trim = gap - max_gap
            cut_start = curr_end + (max_gap / 2)
            cut_end = cut_start + trim
            cuts.append(CutRegion(
                start=cut_start,
                end=cut_end,
                word=f"gap ({gap:.2f}s→{max_gap:.2f}s)",
                confidence=1.0,
            ))

    return sorted(cuts, key=lambda c: c.start)


def detect_retakes(transcript: dict, similarity_threshold: float = 0.6, window_s: float = 15.0) -> list[CutRegion]:
    """Detect repeated lines (retakes) and mark earlier instances for cutting.

    Compares sentence-level chunks within a sliding time window. When two chunks
    are similar enough, the earlier one is a failed take — cut it, keep the later one.
    """
    # Build sentence-level chunks from word timestamps
    chunks = []
    current_words = []
    current_start = None

    for segment in transcript.get("segments", []):
        for word in segment.get("words", []):
            w_text = word.get("word", "").strip()
            w_start = word.get("start", 0)
            w_end = word.get("end", 0)
            if not w_text:
                continue

            if current_start is None:
                current_start = w_start
            current_words.append(w_text)

            # Split on sentence boundaries or long pauses (> 1s)
            is_sentence_end = w_text.rstrip().endswith((".", "!", "?"))
            next_words = segment.get("words", [])
            word_idx = next_words.index(word) if word in next_words else -1
            has_long_pause = False
            if word_idx >= 0 and word_idx + 1 < len(next_words):
                gap = next_words[word_idx + 1].get("start", 0) - w_end
                has_long_pause = gap > 1.0

            if is_sentence_end or has_long_pause or len(current_words) >= 15:
                text = " ".join(current_words).lower().strip()
                text = re.sub(r"[^\w\s]", "", text)
                if len(current_words) >= 3:  # Skip tiny fragments
                    chunks.append({
                        "text": text,
                        "start": current_start,
                        "end": w_end,
                        "word_count": len(current_words),
                    })
                current_words = []
                current_start = None

    # Flush remaining words
    if current_words and current_start is not None and len(current_words) >= 3:
        text = " ".join(current_words).lower().strip()
        text = re.sub(r"[^\w\s]", "", text)
        last_seg = transcript.get("segments", [])[-1]
        last_word = last_seg.get("words", [])[-1] if last_seg.get("words") else {}
        chunks.append({
            "text": text,
            "start": current_start,
            "end": last_word.get("end", current_start),
            "word_count": len(current_words),
        })

    # Compare chunks within the time window
    cuts = []
    used = set()  # Track chunks already marked as retakes

    for i in range(len(chunks)):
        if i in used:
            continue
        for j in range(i + 1, len(chunks)):
            if j in used:
                continue
            # Only compare within time window
            if chunks[j]["start"] - chunks[i]["end"] > window_s:
                break

            ratio = difflib.SequenceMatcher(
                None, chunks[i]["text"].split(), chunks[j]["text"].split()
            ).ratio()

            if ratio >= similarity_threshold:
                # Cut the earlier take, keep the later one
                cuts.append(CutRegion(
                    start=chunks[i]["start"],
                    end=chunks[i]["end"],
                    word=f"retake ({ratio:.0%} match)",
                    confidence=ratio,
                ))
                used.add(i)
                break  # This chunk is consumed, move on

    return cuts


def invert_cuts(cuts: list[CutRegion], duration: float, min_segment_ms: float = 100) -> list[KeepRegion]:
    """Convert cut regions to keep regions. Drop segments shorter than min_segment_ms."""
    keeps = []
    pos = 0.0
    min_seg = min_segment_ms / 1000.0

    for cut in sorted(cuts, key=lambda c: c.start):
        if cut.start > pos:
            seg_dur = cut.start - pos
            if seg_dur >= min_seg:
                keeps.append(KeepRegion(start=pos, end=cut.start))
            # else: segment too short, absorb into the cut
        pos = cut.end

    if pos < duration and (duration - pos) >= min_seg:
        keeps.append(KeepRegion(start=pos, end=duration))

    return keeps


# ── Report Generation ──────────────────────────────────────


def print_report(
    cuts: list[CutRegion],
    duration: float,
    preset: str,
    enhance: bool,
):
    """Print dry-run report showing what would happen."""
    total_cut = sum(c.end - c.start for c in cuts)
    pct = (total_cut / duration * 100) if duration > 0 else 0

    click.echo()
    click.echo(click.style("  CAPCUT DRY-RUN REPORT", bold=True))
    click.echo()

    if cuts:
        click.echo(f"  Fillers detected: {len(cuts)}")
        click.echo(f"  Time to remove:   {total_cut:.1f}s ({pct:.1f}% of {duration:.1f}s)")
        click.echo()
        click.echo("  Cuts:")
        for c in cuts[:25]:
            click.echo(
                f"    {c.start:7.2f}s → {c.end:7.2f}s  "
                f"({c.end - c.start:.2f}s)  "
                f'"{c.word}" '
                f"[conf: {c.confidence:.2f}]"
            )
        if len(cuts) > 25:
            click.echo(f"    ... and {len(cuts) - 25} more")
    else:
        click.echo("  No fillers detected.")

    click.echo()
    click.echo(f"  EQ preset:    {preset}")
    click.echo(f"  Enhancement:  {'Resemble Enhance (Studio Sound)' if enhance else 'off'}")
    click.echo()
    click.echo("  Pass --execute to process.")
    click.echo()


def print_json_report(cuts: list[CutRegion], duration: float):
    """Output machine-readable filler report."""
    output = {
        "version": VERSION,
        "duration": duration,
        "fillers": [
            {
                "start": c.start, "end": c.end,
                "duration": round(c.end - c.start, 3),
                "word": c.word, "confidence": c.confidence,
            }
            for c in cuts
        ],
        "total_filler_time": round(sum(c.end - c.start for c in cuts), 3),
        "filler_count": len(cuts),
    }
    click.echo(json.dumps(output, indent=2))


# ── Resemble Enhance (Studio Sound) ───────────────────────


def enhance_audio(audio_path: Path, output_path: Path, use_cache: bool = True, force_cpu: bool = False) -> Path:
    """Run Resemble Enhance for AI denoising + bandwidth restoration."""
    cache_key = file_hash(audio_path)
    cache_file = ENHANCE_CACHE / f"{cache_key}.wav"

    if use_cache and cache_file.exists():
        click.echo(f"  Using cached enhancement: {cache_file.name}")
        # Copy to output
        subprocess.run(["cp", str(cache_file), str(output_path)], check=True)
        return output_path

    click.echo(f"  {CYAN}◐{RESET} Running Resemble Enhance...")
    t0 = time.time()

    # Enable MPS fallback for unsupported ops (weight_norm)
    os.environ["PYTORCH_ENABLE_MPS_FALLBACK"] = "1"

    # Let tqdm show chunk progress (resemble_enhance uses trange over 30s chunks)
    os.environ.pop("TQDM_DISABLE", None)

    import torch
    import torchaudio

    # Determine device — force CPU to avoid MPS memory pressure crashes
    if force_cpu or not torch.backends.mps.is_available():
        device = "cpu"
        click.echo(f"    {DIM}Device: CPU{' (forced — stable)' if force_cpu else ''}{RESET}")
    else:
        device = "mps"
        click.echo(f"    {DIM}Device: Metal (MPS){RESET}")

    # Load audio
    click.echo(f"    {DIM}Loading audio...{RESET}")
    audio, sr = torchaudio.load(str(audio_path))
    if audio.shape[0] > 1:
        audio = audio.mean(dim=0, keepdim=True)
    audio = audio.squeeze()
    dur_sec = len(audio) / sr
    click.echo(f"    {DIM}{dur_sec:.0f}s @ {sr}Hz → denoise + bandwidth restore{RESET}")

    # Run enhancement
    from resemble_enhance.enhancer.inference import enhance

    enhanced, new_sr = enhance(
        audio,
        sr,
        device=device,
        nfe=64,
        solver="midpoint",
        lambd=0.1,
        tau=0.5,
    )

    # Save
    if enhanced.dim() == 1:
        enhanced = enhanced.unsqueeze(0)
    torchaudio.save(str(output_path), enhanced.cpu(), new_sr)

    elapsed = time.time() - t0
    click.echo(f"    {DIM}Enhanced in {elapsed:.1f}s{RESET}")

    # Cache
    ENHANCE_CACHE.mkdir(parents=True, exist_ok=True)
    subprocess.run(["cp", str(output_path), str(cache_file)], check=True)

    return output_path


