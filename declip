            table.add_column("Time", style="bold", no_wrap=True)
            table.add_column("Dur", justify="right", no_wrap=True)
            table.add_column("Type")
            table.add_column("Conf", justify="right", no_wrap=True)

            display_cuts = cuts[:30]
            for c in display_cuts:
                dur = c.end - c.start
                conf_style = "dodger_blue2" if c.confidence >= 0.8 else ("yellow" if c.confidence >= 0.5 else "red")
                table.add_row(
                    f"{c.start:7.2f}s → {c.end:7.2f}s",
                    f"{dur:.2f}s",
                    c.word,
                    Text(f"{c.confidence:.2f}", style=conf_style),
                )
            if len(cuts) > 30:
                table.add_row("", "", f"[muted]... +{len(cuts) - 30} more[/muted]", "")

            console.print(table)
        else:
            console.print("  No fillers detected.")

        console.print()
