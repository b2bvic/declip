    if PRESETS_FILE.exists():
        return json.loads(PRESETS_FILE.read_text())
    return {
        "victor": {"chain": DEFAULT_PRESET_CHAIN},
        "raw": {"chain": "loudnorm=I=-16:TP=-1.5:LRA=11"},
        "none": {"chain": ""},
    }


def get_eq_chain(preset: str, custom_eq: str | None) -> str:
    """Resolve EQ filter chain from preset or custom override."""
    if custom_eq:
        return custom_eq
    presets = load_presets()
    if preset not in presets:
        raise click.ClickException(
            f"Unknown preset '{preset}'. Available: {', '.join(presets.keys())}"
        )
    return presets[preset].get("chain", "")


# ── FFmpeg Command Building ────────────────────────────────


def build_cut_cmd(
    input_path: Path,
    output_path: Path,
    keeps: list[KeepRegion],
    eq_chain: str,
    has_vid: bool,
    crossfade_ms: float,
    verbose: bool,
) -> list[str]:
    """Build ffmpeg command for cutting + EQ in one pass."""
    n = len(keeps)

    if n == 0:
        raise click.ClickException("No keep regions — entire file would be removed")

    if n == 1:
        # Simple trim, no concat needed
        k = keeps[0]
        cmd = ["ffmpeg", "-y"]
        if not verbose:
            cmd += ["-v", "quiet", "-stats"]
        cmd += ["-i", str(input_path)]

        if has_vid:
            cmd += ["-ss", str(k.start), "-to", str(k.end)]
            if eq_chain:
                cmd += ["-af", eq_chain]
            cmd += [
                "-c:v", "h264_videotoolbox", "-q:v", "65",
                "-c:a", "aac_at", "-b:a", "192k", "-ar", "48000",
            ]
        else:
            cmd += ["-ss", str(k.start), "-to", str(k.end)]
            if eq_chain:
                cmd += ["-af", eq_chain]
            cmd += ["-c:a", "aac_at", "-b:a", "192k", "-ar", "48000"]

        cmd.append(str(output_path))
        return cmd

    # Multiple segments: use concat demuxer approach for reliability
    # Build segment list, trim each, then concat
    cf = crossfade_ms / 1000.0

    # For complex filtergraph approach (< 200 segments) — single-pass, no sync drift
    if n <= 200:
        return _build_filtergraph_cmd(
            input_path, output_path, keeps, eq_chain, has_vid, cf, verbose
        )
    else:
        return _build_segment_cmd(
            input_path, output_path, keeps, eq_chain, has_vid, verbose
        )


def _build_filtergraph_cmd(
    input_path: Path,
    output_path: Path,
    keeps: list[KeepRegion],
    eq_chain: str,
    has_vid: bool,
    crossfade: float,
    verbose: bool,
) -> list[str]:
    """Build single-pass complex filtergraph for < 50 segments."""
    n = len(keeps)
    cmd = ["ffmpeg", "-y"]
    if not verbose:
        cmd += ["-v", "quiet", "-stats"]

    if has_vid:
        cmd += ["-hwaccel", "videotoolbox"]

    cmd += ["-i", str(input_path)]

    # Build audio filtergraph
    audio_parts = []
    video_parts = []

    for i, k in enumerate(keeps):
        audio_parts.append(
            f"[0:a]atrim=start={k.start:.3f}:end={k.end:.3f},asetpts=PTS-STARTPTS[a{i}]"
        )
        if has_vid:
            video_parts.append(
                f"[0:v]trim=start={k.start:.3f}:end={k.end:.3f},setpts=PTS-STARTPTS[v{i}]"
            )

    # Concat audio segments
    audio_labels = "".join(f"[a{i}]" for i in range(n))
    audio_concat = f"{audio_labels}concat=n={n}:v=0:a=1[aconcat]"

    # Apply EQ after concat
    if eq_chain:
        audio_final = f"[aconcat]{eq_chain}[aout]"
        audio_out = "[aout]"
    else:
        audio_final = None
        audio_out = "[aconcat]"

    # Build full filtergraph
    fg_parts = audio_parts + [audio_concat]
    if audio_final:
        fg_parts.append(audio_final)

    if has_vid:
        fg_parts.extend(video_parts)
        video_labels = "".join(f"[v{i}]" for i in range(n))
        video_concat = f"{video_labels}concat=n={n}:v=1:a=0[vout]"
        fg_parts.append(video_concat)

    filtergraph = ";".join(fg_parts)
    cmd += ["-filter_complex", filtergraph]

    if has_vid:
        cmd += [
            "-map", "[vout]", "-map", audio_out,
            "-c:v", "h264_videotoolbox", "-q:v", "65",
            "-c:a", "aac_at", "-b:a", "192k", "-ar", "48000",
        ]
    else:
        cmd += [
            "-map", audio_out,
            "-c:a", "aac_at", "-b:a", "192k", "-ar", "48000",
        ]

    cmd.append(str(output_path))
    return cmd


def _build_segment_cmd(
    input_path: Path,
    output_path: Path,
    keeps: list[KeepRegion],
    eq_chain: str,
    has_vid: bool,
    verbose: bool,
) -> list[str]:
    """Segment-based concat for 50+ cuts. Uses concat demuxer."""
    # Write segment list to temp file alongside output
    tmp_dir = output_path.parent
    segments_dir = tmp_dir / "segments"
    segments_dir.mkdir(exist_ok=True)

    # Extract each keep region — re-encode for frame-accurate cuts
    segment_files = []
    n = len(keeps)
    if not IS_TTY:
        click.echo(f"  {CYAN}◐{RESET} Cutting {n} segments...")
    milestones = {25, 50, 75, 100}
    for i, k in enumerate(keeps):
        seg_file = segments_dir / f"seg_{i:04d}.mp4"
        progress_tick(i, n, "Cutting segment", milestones)
        seg_dur = k.end - k.start
        # Apply 15ms audio fade in/out on each segment for smooth transitions
        fade_out_start = max(0, seg_dur - 0.015)
        af = f"afade=t=in:d=0.015,afade=t=out:st={fade_out_start:.4f}:d=0.015"
        cmd = ["ffmpeg", "-y", "-v", "quiet",
               "-i", str(input_path),
               "-ss", str(k.start), "-to", str(seg_dur),
               "-c:v", "h264_videotoolbox", "-q:v", "65",
               "-af", af, "-c:a", "aac_at", "-b:a", "192k",
               str(seg_file)]
        result = subprocess.run(cmd, capture_output=True, text=True)
        if result.returncode != 0:
            raise click.ClickException(f"Segment {i} extraction failed: {result.stderr.strip()}")
        segment_files.append(seg_file)
    if IS_TTY:
        sys.stdout.write(f"\r{CLEAR_LINE}")
        sys.stdout.flush()

    # Write concat demuxer file
    concat_file = tmp_dir / "concat.txt"
    with open(concat_file, "w") as f:
        for seg in segment_files:
            f.write(f"file '{seg}'\n")

    # Build concat + EQ command (per-segment fades already baked in)
    cmd = ["ffmpeg", "-y"]
    if not verbose:
        cmd += ["-v", "quiet", "-stats"]
    cmd += ["-f", "concat", "-safe", "0", "-i", str(concat_file)]

    if eq_chain:
        cmd += ["-af", eq_chain]

    if has_vid:
        # Segments already re-encoded to H.264 — concat can stream copy video
        if eq_chain:
            cmd += ["-c:v", "copy", "-af", eq_chain,
                    "-c:a", "aac_at", "-b:a", "192k", "-ar", "48000"]
        else:
            cmd += ["-c", "copy"]
    else:
        if eq_chain:
            cmd += ["-af", eq_chain, "-c:a", "aac_at", "-b:a", "192k", "-ar", "48000"]
        else:
            cmd += ["-c:a", "copy"]

    cmd.append(str(output_path))
    return cmd


def build_eq_only_cmd(
    input_path: Path,
    output_path: Path,
    eq_chain: str,
    has_vid: bool,
    verbose: bool,
) -> list[str]:
    """Build ffmpeg command for EQ-only processing (no cuts)."""
    cmd = ["ffmpeg", "-y"]
    if not verbose:
        cmd += ["-v", "quiet", "-stats"]

    cmd += ["-i", str(input_path)]

    if has_vid:
        if eq_chain:
            cmd += ["-af", eq_chain]
        cmd += [
            "-c:v", "copy",
            "-c:a", "aac_at", "-b:a", "192k", "-ar", "48000",
        ]
    else:
        if eq_chain:
            cmd += ["-af", eq_chain]
        cmd += ["-c:a", "aac_at", "-b:a", "192k", "-ar", "48000"]

    cmd.append(str(output_path))
    return cmd


def replace_audio_in_video(
    video_path: Path,
    audio_path: Path,
    output_path: Path,
    eq_chain: str,
    verbose: bool,
) -> list[str]:
    """Mux enhanced audio back into video container."""
    cmd = ["ffmpeg", "-y"]
    if not verbose:
        cmd += ["-v", "quiet", "-stats"]
    cmd += [
        "-i", str(video_path),
        "-i", str(audio_path),
        "-map", "0:v", "-map", "1:a",
    ]
    if eq_chain:
        cmd += ["-af", eq_chain]
    cmd += [
        "-c:v", "copy",
        "-c:a", "aac_at", "-b:a", "192k", "-ar", "48000",
    ]
    cmd.append(str(output_path))
    return cmd


# ── Execution ──────────────────────────────────────────────


def run_ffmpeg(cmd: list[str]):
    """Execute an ffmpeg command."""
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        stderr = result.stderr.strip()
        # Extract the useful error line
        lines = stderr.split("\n")
        error_lines = [l for l in lines if "error" in l.lower() or "Error" in l]
        msg = error_lines[-1] if error_lines else lines[-1] if lines else "Unknown error"
        raise click.ClickException(f"ffmpeg failed: {msg}")


def write_audit(record: dict):
    """Append to audit log."""
    AUDIT_LOG.parent.mkdir(parents=True, exist_ok=True)
    with open(AUDIT_LOG, "a") as f:
        f.write(json.dumps(record, default=str) + "\n")


